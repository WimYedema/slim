    "jsdom": "^29.0.2",
    "svelte": "^5.55.1",
    "svelte-check": "^4.4.6",
    "typescript": "~6.0.2",
    "vite": "^8.0.4",
    "vite-plugin-singlefile": "^2.3.2",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "nostr-tools": "^2.23.3"
